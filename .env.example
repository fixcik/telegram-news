# Telegram API credentials — get from https://my.telegram.org/apps
TG_API_ID=
TG_API_HASH=

# OpenRouter API key — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Bot tokens are now stored in the SQLite DB and managed via the web UI (/bots).
# For first-time bootstrap from groups.yaml, use `telegram-news import-yaml`,
# which reads bot tokens from env vars referenced by `token_env` and writes
# them into the DB. After import, the env vars are no longer needed.
